      const mockRequire = (moduleName) => {
        if (dependencies[moduleName]) {
          return dependencies[moduleName];
        }
        throw new Error(\`Module not found: '\${moduleName}'\`);
      };

      let pendingPromises = new Set();
      let pendingTimers = new Set();

      const originalPromise = Promise;
      self.Promise = function (...args) {
        const promise = new originalPromise(...args);
        pendingPromises.add(promise);
        promise.then(() => pendingPromises.delete(promise), () => pendingPromises.delete(promise));
        return promise;
      };

      // Maintain static methods of Promise
      Object.getOwnPropertyNames(originalPromise).forEach(prop => {
        if (prop !== 'prototype' && typeof originalPromise[prop] === 'function') {
          self.Promise[prop] = function(...args) {
            const result = originalPromise[prop].apply(originalPromise, args);
            if (result instanceof originalPromise) {
              pendingPromises.add(result);
              result.then(() => pendingPromises.delete(result), () => pendingPromises.delete(result));
            }
            return result;
          };
        }
      });

      const originalSetTimeout = self.setTimeout;
      self.setTimeout = function (callback, delay, ...args) {
        const timer = originalSetTimeout(() => {
