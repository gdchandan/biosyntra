            return JSON.stringify(arg);
          } catch (error) {
            return '[Unstringifiable Value]';
          }
        }
        return String(arg);
      };

      const logs = [];
      const originalConsole = console;
      console = {
        log: (...args) => {
          const stringifiedArgs = args.map(stringifyArg);
          logs.push(stringifiedArgs.join(' '));
        },
        warn: (...args) => {
          const stringifiedArgs = args.map(stringifyArg);
          logs.push('WARN: ' + stringifiedArgs.join(' '));
        },
        error: (...args) => {
          const stringifiedArgs = args.map(stringifyArg);
          logs.push('ERROR: ' + stringifiedArgs.join(' '));
        }
